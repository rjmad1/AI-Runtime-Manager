# OpenClaw Workstation Manager Git Ignore

# Local Python virtual environment
.venv/
venv/
ENV/

# Output and process logs
logs/
*.log

# Dynamically generated runtime configurations (build artifacts)
generated/

# Configuration backups
backups/

# Python Cache
__pycache__/
*.py[cod]
*$py.class

# IDE configurations
.idea/
.vscode/

# Temporary backups
*.bak

# Packaging artifacts
*.egg-info/
.pytest_cache/

# Local runtime state (schema version, config version history — may contain secrets)
OpenClawManager/history/
OpenClawManager/schema-version.json

# Identity stores and signing keys — never commit
OpenClawManager/users.yaml
OpenClawManager/api_keys.yaml
OpenClawManager/.jwt_secret
